{
  "expo": {
    "name": "Album Mundial 2026",
    "slug": "AlbumMundial2026",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo-album.png",
    "scheme": "albummundial2026",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F5F5F5",
        "foregroundImage": "./assets/images/logo-album.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Permite que $(PRODUCT_NAME) acceda a tu cámara para escanear stickers.",
          "microphonePermission": "Permite que $(PRODUCT_NAME) acceda al micrófono."
        }
      ],
      [
        "expo-splash-screen",
        {
          "microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone",
          "recordAudioAndroid": true,
          "image": "./assets/images/logo-album.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}